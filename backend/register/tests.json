{
  "tests": [
    {
      "name": "Успешная регистрация",
      "method": "POST",
      "path": "/",
      "body": {"name": "Тест Пользователь", "email": "test_connectly_unique@example.com", "password": "password123"},
      "expectedStatus": 200,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Дубликат email",
      "method": "POST",
      "path": "/",
      "body": {"name": "Тест", "email": "test_connectly_unique@example.com", "password": "password123"},
      "expectedStatus": 409,
      "expectedBody": {"error": "Пользователь с таким email уже существует"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Пустые поля",
      "method": "POST",
      "path": "/",
      "body": {"name": "", "email": "", "password": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "Заполните все поля"},
      "bodyMatcher": "partial"
    }
  ]
}
